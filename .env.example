# Copy to .env.local and fill in values. Never commit .env.local.

# --- Seller / paywall (Arc testnet) ---
NEXT_PUBLIC_SELLER_ADDRESS=
SELLER_PRIVATE_KEY=
NEXT_PUBLIC_CHAIN_ARC=arcTestnet
NEXT_PUBLIC_RPC_ARC=https://rpc.testnet.arc.network
NEXT_PUBLIC_USDC_ARC=0x3600000000000000000000000000000000000000

# --- User wallet (Base mainnet) — Top Up + balance in UI ---
NEXT_PUBLIC_FUND_CHAIN_ID=8453
NEXT_PUBLIC_USDC_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_RPC_BASE=https://mainnet.base.org

# --- Privy (login + embedded wallet) ---
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Server-side tx signing (copy private key from Privy Dashboard → Authorization keys)
# PRIVY_AUTHORIZATION_PRIVATE_KEY=wallet-auth:...
# Key quorum id from Dashboard (same value can be public for addSigners)
# PRIVY_SIGNER_QUORUM_ID=
# NEXT_PUBLIC_PRIVY_SIGNER_QUORUM_ID=

# --- Supabase (API keys + payments) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Optional: separate pepper for API key hashing (defaults to PRIVY_APP_SECRET)
# API_KEY_HASH_SECRET=

# --- Agents (MCP / Eliza / scripts) — bill owner's Base wallet via API key ---
# CRAWLPAY_API_KEY=cr_live_...
# CRAWLPAY_AGENT_API_KEY=cr_live_...
# CRAWLPAY_BOT_USER_AGENT=GPTBot (CrawlPay-Agent/1.0)

# On-chain USDC transfer on each API-key hit (requires Privy wallet id + seller address)
# CRAWLPAY_API_KEY_ONCHAIN=true

# --- Vault demo (optional) ---
# CRAWLPAY_VAULT_UUID=
# PINATA_JWT=
# PINATA_GATEWAY=
# STORY_PRIVATE_KEY=
